{
  "name": "replay-service",
  "private": true,
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "build": "lerna run build --parallel",
    "start": "lerna run start --parallel",
    "start:dev:api": "lerna run start:dev --scope=@replay-service/api",
    "test": "lerna run test --parallel",
    "test:e2e": "lerna run test:e2e --parallel",
    "lint": "eslint . --max-warnings=0",
    "typescript": "tsc --noEmit",
    "format": "prettier --write \"projects/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "lerna": "^6.0.1",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
